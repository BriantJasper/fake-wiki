# --- Database (required) -----------------------------------------------------
# Neon Postgres connection string. Get one free at https://neon.tech.
# Use the pooled connection URL.
DATABASE_URL="postgresql://user:pass@host.neon.tech/fake_wiki?sslmode=require"

# --- LLM providers -----------------------------------------------------------
# Anthropic API key (https://console.anthropic.com). Used for article writing.
ANTHROPIC_API_KEY="sk-ant-..."

# Groq API key (https://console.groq.com). Free tier; used for cheap ops
# (slug normalization, plausibility scoring, random title seeds, fallback).
GROQ_API_KEY="gsk_..."

# Optional soft cap (USD/day). When today's Anthropic spend exceeds this,
# the LLM router transparently falls back to Groq for article writing.
# Leave unset to always use Anthropic when key is present.
# ANTHROPIC_DAILY_SOFT_CAP_USD="5"

# --- Rate limiting (required for production, optional for local dev) ---------
# Upstash Redis (https://upstash.com). Used for rate limiting and budget
# tracking. Without these, both fall back to no-op behavior in development.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Public site config ------------------------------------------------------
# Used for OG meta tags + canonical URLs. No trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Atlas of Nowhere"
